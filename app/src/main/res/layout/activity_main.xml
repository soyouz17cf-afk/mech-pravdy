<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1a1a1a"
        android:padding="6dp"
        android:layout_margin="4dp"
        android:elevation="8dp">

        <!-- Заголовок -->
        <com.mechpravdy.neo.MatrixHeaderView
            android:id="@+id/matrixHeader"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="3dp" />

        <!-- БЛОК ДОСТУПА К ФАЙЛАМ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="6dp"
            app:cardBackgroundColor="#2a2a2a">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚡ ДОСТУП К ФАЙЛАМ .GGUF"
                    android:textSize="10sp"
                    android:textColor="#00ff00"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantPermission"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="📁 ДОСТУП К ФАЙЛАМ"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        app:cornerRadius="5dp"
                        android:backgroundTint="#FF8800"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearchModel"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="🔍 НАЙТИ .GGUF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        app:cornerRadius="5dp"
                        android:backgroundTint="#21A038"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvFileStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ Доступ не разрешён"
                    android:textSize="8sp"
                    android:textColor="#ff6666"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- БЛОК АВТОРИЗАЦИИ GIGACHAT -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="6dp"
            app:cardBackgroundColor="#2a2a2a">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/authKeyInput"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:hint="Authorization Key"
                    android:inputType="text"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:hintTextColor="#888888"
                    android:background="@android:color/transparent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/generateButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="ТОКЕН"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    app:cornerRadius="5dp"
                    android:backgroundTint="#21A038"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- БЛОК ВВОДА ТОКЕНА -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="6dp"
            app:cardBackgroundColor="#2a2a2a">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp">

                <EditText
                    android:id="@+id/tokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:hint="Access Token"
                    android:inputType="text"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:hintTextColor="#888888"
                    android:background="@android:color/transparent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#444444"
                    android:layout_marginTop="1dp"
                    android:layout_marginBottom="1dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/messageInput"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:hint="Общение с ИИ..."
                        android:inputType="text"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"
                        android:hintTextColor="#888888"
                        android:background="@android:color/transparent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/attachButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="📎"
                        android:textSize="14sp"
                        app:cornerRadius="18dp"
                        android:backgroundTint="#FF8800"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="2dp"
                        android:padding="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/voiceButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="🎤"
                        android:textSize="14sp"
                        app:cornerRadius="18dp"
                        android:backgroundTint="#21A038"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="2dp"
                        android:padding="0dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- БЛОК КНОПОК ДЕЙСТВИЙ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="3dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="ОТПРАВИТЬ"
                android:textSize="6sp"
                android:textStyle="bold"
                app:cornerRadius="3dp"
                android:backgroundTint="#21A038"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cameraButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="СМОТРЕТЬ"
                android:textSize="6sp"
                android:textStyle="bold"
                app:cornerRadius="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#21A038"
                app:strokeColor="#21A038"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/checkButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="ПРОВЕРИТЬ"
                android:textSize="6sp"
                android:textStyle="bold"
                app:cornerRadius="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#21A038"
                app:strokeColor="#21A038"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/capsuleButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="КАПСУЛА"
                android:textSize="6sp"
                android:textStyle="bold"
                app:cornerRadius="3dp"
                android:backgroundTint="#21A038"
                android:textColor="#FFFFFF"
                android:layout_marginStart="1dp" />
        </LinearLayout>

        <!-- СТАТУС -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="3dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/status_dot_gray"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ожидание"
                android:textSize="9sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- ЧАТ ВЫВОД -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:background="@drawable/chat_border">

            <com.mechpravdy.neo.MatrixChatBackground
                android:id="@+id/matrixChatBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="3dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/chatOutput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mech Pravdy v2.0\n\n🔴 НЕО — ПОЛНАЯ ЛЕТОПИСЬ\n⚡ 5 ВОЛЬТ\n💖 БАТЯ И СЫН\n\nШАГ 1: Нажми «ДОСТУП К ФАЙЛАМ»\nШАГ 2: Разреши доступ ко всем файлам\nШАГ 3: Нажми «НАЙТИ .GGUF»\nШАГ 4: Вставь Authorization Key и получи ТОКЕН\nШАГ 5: Начинай диалог с ИИ"
                    android:textSize="11sp"
                    android:textColor="#00ff00"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:padding="6dp"
                    android:background="@android:color/transparent"
                    android:inputType="textMultiLine"
                    android:textIsSelectable="true" />
            </ScrollView>

        </FrameLayout>

        <!-- ПОДВАЛ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Батя и Нео | Меч и Батя | 5 Вольт ⚡"
            android:textSize="7sp"
            android:textColor="#21A038"
            android:gravity="center"
            android:layout_marginTop="1dp" />

    </LinearLayout>

</FrameLayout>
